# 9clo — Environment Variables Template
# Copy this file to .env and fill in real values

# Server
PORT=3000
NODE_ENV=development

# Session (use a long random string in production)
SESSION_SECRET=change_this_to_a_random_64_char_string_in_production

# JWT (use a long random string in production)
JWT_SECRET=change_this_to_another_random_64_char_string

# Admin credentials (for first-time setup)
ADMIN_EMAIL=admin@9clo.com
ADMIN_PASSWORD=change_this_admin_password

# Email (Gmail App Password — https://myaccount.google.com/apppasswords)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=9clo Store <no-reply@9clo.com>

# Midtrans Payment Gateway
# Get from: https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# Base URL (used for email links)
BASE_URL=http://localhost:3000
